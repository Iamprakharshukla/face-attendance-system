# ═════════════════════════════════════════════════════════════
# AI ATTENDANCE SYSTEM - ENVIRONMENT CONFIGURATION
# ═════════════════════════════════════════════════════════════

# ─────────────────────────────────────────────────────────────
# FLASK CONFIGURATION
# ─────────────────────────────────────────────────────────────
DEBUG=True
SECRET_KEY=your-secret-key-change-this-in-production

# ─────────────────────────────────────────────────────────────
# EMAIL CONFIGURATION (For sending attendance reports)
# ─────────────────────────────────────────────────────────────
# Gmail Setup:
# 1. Enable 2-factor authentication on your Gmail account
# 2. Visit: https://myaccount.google.com/apppasswords
# 3. Generate an App Password and use it below
# 4. Replace 'your-email@gmail.com' with your actual Gmail address

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=08prince999@gmail.com
MAIL_PASSWORD=vztxtmrrpgrxedmo
MAIL_DEFAULT_SENDER=08prince999@gmail.com

# ─────────────────────────────────────────────────────────────
# ORGANIZATION SETTINGS
# ─────────────────────────────────────────────────────────────
# Email address where attendance reports will be sent
ORGANIZATION_EMAIL=admin@organization.com

# ─────────────────────────────────────────────────────────────
# FACE RECOGNITION SETTINGS
# ─────────────────────────────────────────────────────────────
# Model: 'hog' (faster, CPU) or 'cnn' (slower, GPU but more accurate)
FACE_RECOGNITION_MODEL=hog

# ─────────────────────────────────────────────────────────────
# SESSION CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Set to True in production with HTTPS enabled
SESSION_COOKIE_SECURE=False

# ─────────────────────────────────────────────────────────────
# LOGGING CONFIGURATION
# ─────────────────────────────────────────────────────────────
# Log level: 'DEBUG' (verbose), 'INFO' (normal), 'WARNING' (less verbose)
LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# ATTENDANCE LOGGING SETTINGS
# ─────────────────────────────────────────────────────────────
# Prevent duplicate attendance logging within this interval (seconds)
# Example: 60 = only log same person once per minute
ATTENDANCE_DEDUP_INTERVAL=60

# Log unknown faces every N frames (higher = less logging)
# Example: 10 = log every 10 frames (reduces noise)
UNKNOWN_FACE_LOG_FREQUENCY=10
